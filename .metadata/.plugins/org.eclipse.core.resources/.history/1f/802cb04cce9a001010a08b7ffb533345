  -->
  <form th:action="@{/poly/product/save}" th:object="${product}" method="post">
    <label>
      Name:
      <input type="text" th:field="*{name}" />
    </label>
    <br/>
    <label>
      Price:
      <input type="number" th:field="*{price}" step="0.01" />
    </label>
    <br/>
    <button type="submit">Save</button>
  </form>

  <ul>
    <li>Name: <span th:text="*{name}">[name]</span></li>
    <li>Price: <span th:text="*{price}">[price]</span></li>
  </ul>

</body>
</html>
